# WelOPC AI HOT backend
AIHOT_APP_ROOT=/opt/welopc-ai-signal-radar
AIHOT_RUNTIME_ROOT=/opt/welopc-ai-signal-radar-runtime
AIHOT_WEB_ROOT=/var/www/welopc-ai-signal-radar
AIHOT_DB_PATH=/opt/welopc-ai-signal-radar-runtime/aihot_repro.sqlite3
AIHOT_LATEST_JSON=/var/www/welopc-ai-signal-radar/data/latest.json
AIHOT_CREDENTIALS_PATH=/opt/welopc-ai-signal-radar-runtime/admin-credentials.txt
AIHOT_OPC_CONFIG=/opt/welopc-ai-signal-radar/configs/opc_intelligence.json
AIHOT_MP_SOURCES=/opt/welopc-ai-signal-radar/configs/mp_sources.json
AIHOT_BOOTSTRAP_PASSWORD=change-me-before-first-run

# Optional model enrichment
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING=enabled
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_TIMEOUT_SECONDS=75
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_RETRY_DELAY_SECONDS=1.5
